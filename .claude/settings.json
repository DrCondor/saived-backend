{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(bin/rails*)",
      "Bash(bin/rake*)",
      "Bash(bin/rubocop*)",
      "Bash(bin/brakeman*)",
      "Bash(bin/setup*)",
      "Bash(bundle*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(git reset*)",
      "Bash(git rev-parse*)",
      "Bash(git symbolic-ref*)",
      "Bash(git mv*)",
      "Bash(git ls-files*)",
      "Bash(git show*)",
      "Bash(git worktree*)",
      "Bash(gh pr*)",
      "Bash(gh run*)",
      "Bash(gh issue*)",
      "Bash(gh api*)",
      "Bash(gh secret*)",
      "Bash(gh variable*)",
      "Bash(gh repo*)",
      "Bash(gh auth status*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(yarn*)",
      "Bash(node *)",
      "Bash(bun*)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(wc *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(true)",
      "Bash(false)",
      "Bash(env)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(make *)"
    ],
    "deny": [
      "Bash(bin/rails db:reset*)",
      "Bash(bin/rails db:drop*)",
      "Bash(rm -rf*)",
      "Bash(git push --force*main*)",
      "Bash(git push -f*main*)",
      "Read(.env*)",
      "Read(**/trello_credentials*)",
      "Read(**/.fly.toml.secrets)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre_bash_guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit_log.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit_log.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit_log.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "sdlc@terro": true,
    "saived@saived": true,
    "trellosync@saived": true
  }
}
